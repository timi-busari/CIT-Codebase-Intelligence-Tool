# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set ENABLE_OLLAMA=true to use Ollama instead of OpenAI (great for local dev)
ENABLE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OpenAI (used when ENABLE_OLLAMA=false)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Re-ranking (optional) ──────────────────────────────────────────────────
# Cohere API key for re-ranking search results (improves retrieval quality)
COHERE_API_KEY=

# ── GitHub (optional) ──────────────────────────────────────────────────────
# Token for PR analysis and webhook features (needs repo scope)
GITHUB_TOKEN=
